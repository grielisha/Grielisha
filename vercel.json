{
  "version": 2,
  "buildCommand": "cd frontend && npm install && npm run build && cd .. && cp -r frontend/dist dist",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://grielisha-backend.onrender.com/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
